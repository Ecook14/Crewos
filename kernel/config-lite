# CrewOS Kernel Config (Lite Variant) - Ultra Minimal
# Target Size: <8MB bzImage
# Optimized for Firecracker/WSL2/MicroVM

CONFIG_64BIT=y
CONFIG_X86=y
CONFIG_SMP=y
CONFIG_M686=y

# Optimizations
CONFIG_PREEMPT_NONE=y
CONFIG_HZ_100=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_OPTIMIZE_INLINING=y

# Security Hardening
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_RANDOMIZE_BASE=y

# Boot options
CONFIG_CMDLINE="console=ttyS0 quiet panic=1"
CONFIG_CMDLINE_OVERRIDE=y

# Core Features
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_ELF_CORE=y
CONFIG_BASE_FULL=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_SHMEM=y
CONFIG_AIO=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMBARRIER=y
CONFIG_KALLSYMS=n

# Disabling Non-Essential Bus Support
# CONFIG_ISA is not set
# CONFIG_EISA is not set
# CONFIG_MCA is not set
# CONFIG_SCSI is not set

# Disabling Block Devices (keeping Virtio)
# CONFIG_BLK_DEV_FD is not set
# CONFIG_CDROM is not set

# Disabling Multimedia & Legacy Input
# CONFIG_SOUND is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_INPUT_MOUSE is not set
# CONFIG_INPUT_JOYSTICK is not set
# CONFIG_INPUT_TABLET is not set
# CONFIG_INPUT_TOUCHSCREEN is not set
# CONFIG_INPUT_MISC is not set

# Disabling Legacy Graphics (keeping basic tty)
# CONFIG_FB is not set
# CONFIG_VGA_CONSOLE is not set

# Networking (Minimal)
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
# CONFIG_IPV6 is not set
# CONFIG_WIRELESS is not set
# CONFIG_BT is not set

# Essential File Systems
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
# CONFIG_EXT4_FS is not set
# CONFIG_FAT_FS is not set
# CONFIG_NFS_FS is not set

# Virtualization (Firecracker/MicroVM support)
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# Disabling Kernel Debugging
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_STACKTRACE is not set
