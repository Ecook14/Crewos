# CrewOS Kernel Config (GPU Variant) - High Performance Minimal
# Target Size: <10MB bzImage
# Optimized for Vulkan Compute & HW Acceleration

CONFIG_64BIT=y
CONFIG_X86=y
CONFIG_SMP=y
CONFIG_M686=y

# Performance Optimizations
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_HZ_250=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y

# Security Hardening
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_RANDOMIZE_BASE=y

# Boot options
CONFIG_CMDLINE="console=ttyS0 quiet panic=1"
CONFIG_CMDLINE_OVERRIDE=y

# Core Architecture
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# GPU & Graphics Support (Vukan / DRM)
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_I915=y
CONFIG_DRM_NOUVEAU=y
CONFIG_VGA_ARB=y
CONFIG_SYNC_FILE=y
CONFIG_DMA_SHARED_BUFFER=y

# Disabling Non-Essential Bus Support
# CONFIG_ISA is not set
# CONFIG_EISA is not set
# CONFIG_MCA is not set

# Disabling Block Devices (keeping Virtio)
# CONFIG_BLK_DEV_FD is not set
# CONFIG_CDROM is not set

# Disabling Multimedia & Legacy Input
# CONFIG_SOUND is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_INPUT_MOUSE is not set
# CONFIG_INPUT_JOYSTICK is not set
# CONFIG_INPUT_TABLET is not set
# CONFIG_INPUT_TOUCHSCREEN is not set
# CONFIG_INPUT_MISC is not set

# Networking (Minimal)
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
# CONFIG_WIRELESS is not set
# CONFIG_BT is not set

# Essential File Systems
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# Virtualization (Firecracker/MicroVM support)
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_GPU=y

# Disabling Kernel Debugging
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_STACKTRACE is not set
