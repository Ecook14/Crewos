{
  "boot-source": {
    "kernel_image_path": "../build/linux/arch/x86/boot/bzImage",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off nomodule mitigations=off init=/init"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "../build/crewos-lite.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "machine-config": {
    "vcpu_count": 2,
    "mem_size_mib": 512,
    "smt": false
  }
}
